rules_version = '2';

// Molecule POS — cloud dashboard security rules.
//
// Each restaurant signs in with its own email/password account. That account's
// uid IS the restaurant id, so a signed-in user can only ever touch its own
// node. This is what makes the public Firebase config (shipped in the .exe)
// harmless: the apiKey is just an identifier — these rules are the real lock.
//
// Deploy: Firebase Console → Firestore Database → Rules → paste → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Everything for a restaurant lives under restaurants/{rid} where rid == uid.
    match /restaurants/{rid}/{document=**} {
      // Only the owning account can read its dashboard...
      allow read:  if request.auth != null && request.auth.uid == rid;
      // ...and only the owning account (the POS app, signed in as the same
      // user) can write. The phone/web dashboard only reads in practice.
      allow write: if request.auth != null && request.auth.uid == rid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
