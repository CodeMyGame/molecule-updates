{
  "name": "molecule",
  "version": "1.2.3",
  "description": "Restaurant POS System",
  "author": "Molecule <contact@moleculepos.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win --ia32 -c.electronVersion=22.3.27",
    "release:win": "electron-vite build && electron-builder --win --ia32 -c.electronVersion=22.3.27 --publish always",
    "rebuild": "electron-rebuild -f -w better-sqlite3,@grandchef/node-printer"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@grandchef/node-printer": "^0.8.0",
    "@mapbox/node-pre-gyp": "^2.0.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "firebase": "^11.10.0",
    "googleapis": "^171.4.0",
    "i18next": "^25.10.9",
    "lucide-react": "^0.378.0",
    "node-fetch": "^2.7.0",
    "node-thermal-printer": "^4.6.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^16.6.5",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "whatsapp-web.js": "^1.34.6",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.molecule.pos",
    "productName": "Molecule",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "codemygame",
      "repo": "molecule-updates"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.food-and-drink"
    },
    "dmg": {
      "title": "Molecule",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
